# =========================================================================
# RaaS — environment template. Copy to .env and fill the two API keys.
# Infra defaults below work out of the box with `docker compose up`.
# =========================================================================

# ---- LLM provider switch (single point of control) ----
# Options: deepseek | gemini | bedrock | azure
LLM_PROVIDER=deepseek

# ---- DeepSeek (primary dev provider) — https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=your-deepseek-key-here
DEEPSEEK_MODEL=deepseek-chat

# ---- Gemini (LLM-as-judge; must differ from generator) — https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-key-here
GEMINI_MODEL=gemini-2.5-flash

JUDGE_PROVIDER=gemini
JUDGE_MODEL=gemini-2.5-flash

# ---- Cloud stubs (prod-ready adapters, never called; no keys needed) ----
BEDROCK_MODEL=anthropic.claude-3-5-sonnet
AWS_REGION=us-east-1
AZURE_MODEL=gpt-4o
AZURE_ENDPOINT=

# ---- Infrastructure (compose overrides these with in-network hostnames) ----
QDRANT_URL=http://localhost:6333
POSTGRES_DSN=postgresql://raas:raas@localhost:5432/raas

# ---- Langfuse (headless-init bootstraps org/project/keys on first start) ----
LANGFUSE_HOST=http://localhost:3000
LANGFUSE_PUBLIC_KEY=pk-lf-change-me
LANGFUSE_SECRET_KEY=sk-lf-change-me
LANGFUSE_INIT_ORG_ID=raas-org
LANGFUSE_INIT_ORG_NAME=RaaS
LANGFUSE_INIT_PROJECT_ID=raas
LANGFUSE_INIT_PROJECT_NAME=RaaS
LANGFUSE_INIT_USER_EMAIL=admin@raas.local
LANGFUSE_INIT_USER_NAME=admin
LANGFUSE_INIT_USER_PASSWORD=change-me-please

# ---- Embeddings (local sentence-transformers, free) ----
EMBEDDING_MODEL=intfloat/multilingual-e5-base

# ---- Retrieval improvement (before/after measured in eval/) ----
RERANK_ENABLED=true

# ---- App ----
APP_ENV=dev
API_PORT=8000

# ---- Auth (JWT) ----
# Demo default OFF: endpoints work with an explicit tenant, no token needed.
# Turn ON to require a Bearer JWT whose tenant_id claim matches the request.
AUTH_ENABLED=true
JWT_SECRET=dev-jwt-secret-change-me
AUTH_DEMO_PASSWORD=change-me-demo-password
